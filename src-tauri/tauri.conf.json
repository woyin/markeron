{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "MarkerOn",
  "version": "0.1.4",
  "identifier": "com.markeron.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:fe",
    "beforeBuildCommand": "npm run build:fe"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "MarkerOn",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "tooltip": "MarkerOn - 屏幕标注工具",
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "./icons/installer-icon.ico",
        "sidebarImage": "./icons/installer-sidebar.bmp",
        "languages": ["SimpChinese"]
      },
      "wix": {
        "language": "zh-CN",
        "bannerPath": "./icons/installer-banner-blank.bmp",
        "dialogImagePath": "./icons/installer-dialog.bmp"
      }
    }
  }
}
