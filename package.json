{
  "name": "markeron",
  "version": "0.1.6",
  "description": "轻量级屏幕标注工具 - 按下快捷键，随时在桌面上自由绘画、标注",
  "author": "ifer47 <361301399@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ifer47/markeron.git"
  },
  "bugs": {
    "url": "https://github.com/ifer47/markeron/issues"
  },
  "homepage": "https://github.com/ifer47/markeron#readme",
  "private": true,
  "keywords": [
    "markeron",
    "screen-annotation",
    "drawing",
    "tauri",
    "vue"
  ],
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:fe": "vite",
    "build": "tauri build",
    "build:mac-arm64": "tauri build --target aarch64-apple-darwin",
    "build:msix": "bash scripts/build-msix.sh",
    "build:all": "tauri build && bash scripts/build-msix.sh",
    "build:fe": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\" \"*.{ts,json}\"",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue,css}": [
      "prettier --write",
      "oxlint"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@lucide/vue": "^1.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^6.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@tauri-apps/plugin-autostart": "^2.5.1"
  }
}
